# LLM Provider: "huggingface", "groq", or "openai"
LLM_PROVIDER=huggingface

# HuggingFace Configuration
HUGGINGFACEHUB_API_TOKEN=hf_your_token_here
HF_MODEL_ID=Qwen/Qwen2.5-72B-Instruct

# Groq Configuration (free alternative with better tool calling)
GROQ_API_KEY=gsk_your_key_here
GROQ_MODEL_ID=llama-3.3-70b-versatile

# OpenAI Configuration
OPENAI_API_KEY=sk_your_key_here
OPENAI_MODEL_ID=gpt-4o-mini

# Embedding model (runs locally via sentence-transformers)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ChromaDB
CHROMA_PERSIST_DIR=./chroma_db

# Magento
MAGENTO_STOREFRONT_URL=https://magentodemo.ethnicinfotech.in
MAGENTO_GRAPHQL_URL=https://magentodemo.ethnicinfotech.in/graphql
MAGENTO_PAGE_SIZE=10

# Server
HOST=0.0.0.0
PORT=8000
RELOAD=false
AUTO_INGEST_ON_STARTUP=true
